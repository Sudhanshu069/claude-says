{
  "name": "claude-code-speak",
  "version": "1.0.0",
  "description": "Real-time text-to-speech companion for Claude Code CLI — hear Claude think and narrate as it works",
  "type": "module",
  "bin": {
    "claude-speak": "./bin/claude-speak.js",
    "claude-speak-hook": "./bin/claude-speak-hook.js"
  },
  "files": [
    "bin/",
    "src/"
  ],
  "scripts": {
    "start": "node bin/claude-speak.js",
    "setup": "node bin/claude-speak.js setup",
    "postinstall": "echo '\n  claude-code-speak installed! Run: claude-speak setup\n'"
  },
  "keywords": [
    "claude",
    "claude-code",
    "tts",
    "text-to-speech",
    "accessibility",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/abhishek141001/claude-code-speak"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "optionalDependencies": {
    "@google-cloud/text-to-speech": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
